(ns medley.test-runner
  (:require [clojure.test :refer :all])
  (:import (System.IO Directory)))

(defn collect-result [results result]
  (merge-with + results result))

(defn run-ns-test [ns]
  (require ns)
  (test-ns ns))

(defn test-results [nses]
  (reduce collect-result (map run-ns-test nses)))

(def test-nses ['medley.core-test])

(defn ensure-dir [path]
  (when-not (Directory/Exists path)
    (Directory/CreateDirectory path)))

(defn -main []
  (let [{:keys [fail error]} (test-results test-nses)
        failures (+ fail error)]
    (ensure-dir "tmp")
    (spit "tmp/status-clr.txt" failures)))
